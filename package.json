{
  "name": "@codewithkenzo/blitz",
  "version": "0.1.0-alpha.2",
  "description": "AST-aware fast edit CLI for Pi and MCP workflows",
  "type": "module",
  "license": "MIT",
  "private": false,
  "bin": {
    "blitz": "bin/blitz.js",
    "blitz-mcp": "mcp/blitz-mcp.ts"
  },
  "files": [
    "bin/blitz.js",
    "mcp/blitz-mcp.ts",
    "scripts/mcp-smoke.ts",
    "scripts/resolve-platform-bin.js",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "docs/blitz.md"
  ],
  "optionalDependencies": {
    "@codewithkenzo/blitz-linux-x64-musl": "0.1.0-alpha.2",
    "@codewithkenzo/blitz-linux-arm64-musl": "0.1.0-alpha.2",
    "@codewithkenzo/blitz-darwin-arm64": "0.1.0-alpha.2",
    "@codewithkenzo/blitz-darwin-x64": "0.1.0-alpha.2",
    "@codewithkenzo/blitz-windows-x64": "0.1.0-alpha.2"
  },
  "scripts": {
    "bench": "bun bench/run.ts",
    "bench:llm": "bun bench/llm-tokens.ts",
    "bench:large": "bun bench/deep-large-symbol.ts",
    "bench:small-target": "bun bench/deep-small-target.ts",
    "smoke:mcp": "bun scripts/mcp-smoke.ts",
    "pack:check": "npm pack --dry-run --json",
    "pack:linux-x64-musl": "npm pack ./packages/blitz-linux-x64-musl --json"
  },
  "keywords": [
    "ast",
    "tree-sitter",
    "code-edit",
    "mcp",
    "pi-agent"
  ],
  "devDependencies": {
    "tiktoken": "^1.0.22"
  }
}
