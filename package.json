{
  "name": "@codewithkenzo/blitz",
  "version": "0.1.0-alpha.0",
  "description": "AST-aware fast edit CLI for Pi and MCP workflows",
  "type": "module",
  "license": "MIT",
  "private": false,
  "bin": {
    "blitz": "./bin/blitz.js",
    "blitz-mcp": "./mcp/blitz-mcp.ts"
  },
  "files": [
    "bin/blitz.js",
    "mcp/blitz-mcp.ts",
    "scripts/mcp-smoke.ts",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "docs/blitz.md"
  ],
  "scripts": {
